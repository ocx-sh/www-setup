# setup.ocx.sh — nginx server block (EXAMPLE / reference)
#
# This file is NOT applied by this repo's release pipeline. The live nginx
# config is maintained out-of-band on the host that serves setup.ocx.sh. This
# example documents the routing contract the installers + publish pipeline
# depend on, so the two never drift.
#
# Routing contract:
#   - The per-shell URLs are a REWRITE layer: the friendly /sh, /pwsh, /nu,
#     /fish, /elvish (and /<shell>/next, /<shell>/<VERSION>) carry no files of
#     their own — regex `location`s map them onto the version-major on-disk dirs
#     (latest/, next/, archive/<VERSION>/) the publish pipeline uploads. So
#     `curl -fsSL https://setup.ocx.sh/sh | sh`, `irm https://setup.ocx.sh/pwsh |
#     iex`, `curl -fsSL https://setup.ocx.sh/nu | nu`, etc. each resolve to the
#     latest-stable installer for that shell; /<shell>/next (alias
#     /<shell>/canary) resolves to the prerelease; /<shell>/<VERSION> (optionally
#     with a trailing /install.<ext>) resolves to the pinned copy.
#   - The canonical pinned artifact is /archive/<VERSION>/install.<ext>, served
#     straight from the static root (curl -O friendly).
#   - /dist is a friendly alias for /dist.json (the self-hosted distribution
#     manifest the installers read via OCX_INSTALL_DIST_URL to resolve "latest"
#     and the per-target sha256 + download URL). /releases is a legacy alias
#     pointing at the same manifest.
#   - /docs/ and /actions/ are PROXIED upstream (pre-existing forwards owned by
#     the host config, reproduced here for completeness). Never publish repo
#     artifacts under those prefixes — nginx reroutes them.
#
# Static root layout (uploaded by scripts/publish-installers.sh):
#   $root/archive/<VERSION>/install.sh      pinned (immutable, append-only)
#   $root/archive/<VERSION>/install.ps1     …and .nu / .fish / .elv, all 5 per release
#   $root/latest/install.*                  stable channel pointer (overwritten)
#   $root/next/install.*                    prerelease channel pointer (overwritten)
#   $root/dist.json                         distribution manifest (regenerated every release)

# --- Shell-segment map (http context; place alongside the server block) --------
# Translate the captured /<shell> segment to the installer filename. Evaluated
# lazily, so the $shellseg named-capture set by the regex locations below is
# available when this resolves — and it is consumed by try_files, which (unlike
# default_type) expands variables. Content-type is served as a static text/plain
# in each location (immaterial for `curl | <shell>`, and inline-viewable).
map $shellseg $ocx_file {
    sh      install.sh;
    pwsh    install.ps1;
    nu      install.nu;
    fish    install.fish;
    elvish  install.elv;
}

server {
    listen       443 ssl;
    listen       [::]:443 ssl;
    server_name  setup.ocx.sh;

    # TLS material managed out-of-band (certbot / ACME).
    # ssl_certificate     /etc/letsencrypt/live/setup.ocx.sh/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/setup.ocx.sh/privkey.pem;

    root  /srv/setup.ocx.sh;

    # --- Per-shell friendly URLs (rewrite layer onto the version-major dirs) --
    # Regex locations are tried in order, first match wins. Order matters: bare
    # pointer, then next/canary, then the pinned version (anchored to a leading
    # digit so it can't swallow `next`/`canary`).

    # /sh /pwsh /nu /fish /elvish  ->  latest/ (stable pointer)
    location ~ ^/(?<shellseg>sh|pwsh|nu|fish|elvish)/?$ {
        default_type text/plain;
        try_files /latest/$ocx_file =404;
    }

    # /sh/next  and  /sh/canary  ->  next/ (prerelease pointer); optional /install.<ext>
    location ~ ^/(?<shellseg>sh|pwsh|nu|fish|elvish)/(?:next|canary)(?:/install\.[a-z0-9]+)?/?$ {
        default_type text/plain;
        try_files /next/$ocx_file =404;
    }

    # /sh/<VERSION>  ->  archive/<VERSION>/ (pinned); optional trailing /install.<ext>
    location ~ ^/(?<shellseg>sh|pwsh|nu|fish|elvish)/(?<ocxver>[0-9][^/]*)(?:/install\.[a-z0-9]+)?/?$ {
        default_type text/plain;
        try_files /archive/$ocxver/$ocx_file =404;
    }

    location = /dist {
        try_files /dist.json =404;
        default_type application/json;
    }

    # Legacy alias — kept pointing at the new manifest.
    location = /releases {
        try_files /dist.json =404;
        default_type application/json;
    }

    # --- Upstream forwards (pre-existing; owned by the host config) -----------

    location /docs/ {
        proxy_pass https://ocx.sh/docs/;
    }

    location /actions/ {
        # Forwarded to GitHub Marketplace / GitLab CI Catalog listings.
        proxy_pass https://ocx.sh/actions/;
    }

    # --- Everything else: static files (pinned versions, dist.json, etc.) -----

    location / {
        try_files $uri $uri/ =404;
    }
}
