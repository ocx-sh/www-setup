#
# Alpine integration container. musl libc → installer must pick the
# *-unknown-linux-musl* target.

ARG ALPINE_VERSION=3.20
FROM alpine:${ALPINE_VERSION}

RUN apk add --no-cache \
    bash \
    curl \
    tar \
    xz \
    gzip \
    ca-certificates \
    coreutils \
    findutils \
    shadow

WORKDIR /work
COPY src/install.sh /work/install.sh
COPY src/install.ps1 /work/install.ps1
COPY src/install.nu /work/install.nu
COPY src/install.fish /work/install.fish
COPY src/install.elv /work/install.elv
COPY tests/docker/smoke.sh /work/smoke.sh
COPY tests/docker/install-shells.sh /work/install-shells.sh
COPY tests/docker/activate.sh /work/activate.sh
RUN chmod +x /work/install.* /work/smoke.sh /work/install-shells.sh /work/activate.sh

# Provision every target shell at build time (bash/dash/zsh/ksh/fish/nu/elvish/pwsh).
RUN /work/install-shells.sh

# Non-root user with a real writable HOME — profile modification needs it for
# the SHELL-axis activation test (activate.sh runs as this user).
RUN useradd -m -s /bin/bash tester || adduser -D -s /bin/bash tester

ENV OCX_HOME=/work/.ocx
ENV OCX_NO_MODIFY_PATH=1

# Back-compat: default entrypoint is the root smoke test (keeps OCX_NO_MODIFY_PATH).
# The activation test overrides this via --entrypoint /work/activate.sh.
ENTRYPOINT ["/work/smoke.sh"]
